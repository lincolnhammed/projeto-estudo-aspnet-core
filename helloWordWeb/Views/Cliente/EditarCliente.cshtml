@model Cliente
@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
}
<h1>Editar Produto</h1>

<form method="post">
    <div class="form-group">
        <label asp-for="Name">Nome do Cliente</label>
        <input type="text" class="form-control" asp-for="Name" placeholder="Insira o nome do cliente">
        <small class="form-text text-danger">
            <span asp-validation-for="Name"></span>
        </small>
    </div>

    <div class="form-group">
        <label asp-for="Email">Email</label>
        <input type="email" class="form-control" asp-for="Email" placeholder="Insira o email do cliente">
        <small class="form-text text-danger">
            <span asp-validation-for="Email"></span>
        </small>
    </div>

    <div class="mb-3">
        <label asp-for="Tel" class="form-label">Telefone</label>

        <div class="input-group">
            <span class="input-group-text">+351</span>
            <input type="tel"
                   class="form-control"
                   asp-for="Tel"
                   placeholder="912 345 678"
                   pattern="9[1236][0-9]{7}"
                   maxlength="9">
        </div>
    <button type="submit" class="btn btn-primary">Atualizar</button>
</form>

<p><a asp-action="Index">Voltar à lista de produtos</a></p>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}