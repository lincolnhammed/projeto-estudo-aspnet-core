@page
@model RegisterModel

@{
    ViewData["Title"] = "Criar Conta";
}

<div class="container d-flex justify-content-center align-items-center vh-100">
    <div class="col-md-5">

        <div class="card shadow-lg border-0 rounded-4">
            <div class="card-body p-4">

                <h2 class="text-center mb-4">📝 Criar Conta</h2>

                <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">

                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <!-- Email -->
                    <div class="form-floating mb-3">
                        <input asp-for="Input.Email" class="form-control" placeholder="nome@exemplo.com" />
                        <label asp-for="Input.Email">Email</label>
                        <span asp-validation-for="Input.Email" class="text-danger"></span>
                    </div>

                    <!-- Password -->
                    <div class="form-floating mb-3">
                        <input asp-for="Input.Password" type="password" class="form-control" placeholder="Palavra-passe" />
                        <label asp-for="Input.Password">Palavra-passe</label>
                        <span asp-validation-for="Input.Password" class="text-danger"></span>
                    </div>

                    <!-- Confirm Password -->
                    <div class="form-floating mb-3">
                        <input asp-for="Input.ConfirmPassword" type="password" class="form-control" placeholder="Confirmar palavra-passe" />
                        <label asp-for="Input.ConfirmPassword">Confirmar palavra-passe</label>
                        <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
                    </div>

                    <!-- Button -->
                    <button id="registerSubmit" type="submit" class="btn btn-success w-100 btn-lg">
                        Criar Conta
                    </button>

                    <!-- Links -->
                    <div class="text-center mt-3">
                        <a asp-page="./Login" class="d-block">
                            Já tens conta? Entrar
                        </a>
                    </div>

                </form>
            </div>
        </div>

        <!-- External login -->
        <div class="card mt-3 shadow-sm border-0 rounded-4">
            <div class="card-body text-center">

                <h5 class="mb-3">Ou regista-te com:</h5>

                @{
                    if ((Model.ExternalLogins?.Count ?? 0) == 0)
                    {
                        <p class="text-muted small">
                            Nenhum serviço externo configurado.
                        </p>
                    }
                    else
                    {
                        <form asp-page="./ExternalLogin" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                            @foreach (var provider in Model.ExternalLogins!)
                            {
                                <button type="submit" class="btn btn-outline-dark w-100 mb-2"
                                        name="provider" value="@provider.Name">
                                    Registar com @provider.DisplayName
                                </button>
                            }
                        </form>
                    }
                }

            </div>
        </div>

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}