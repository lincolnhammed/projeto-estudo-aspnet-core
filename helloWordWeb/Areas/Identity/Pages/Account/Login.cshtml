@page
@model LoginModel

@{
    ViewData["Title"] = "Entrar";
}

<div class="container d-flex justify-content-center align-items-center vh-100">
    <div class="col-md-5">
        <div class="card shadow-lg border-0 rounded-4">
            <div class="card-body p-4">

                <h2 class="text-center mb-4">🔐 Entrar na Conta</h2>

                <form id="account" method="post">

                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <!-- Email -->
                    <div class="form-floating mb-3">
                        <input asp-for="Input.Email" class="form-control" placeholder="nome@exemplo.com" />
                        <label asp-for="Input.Email">Email</label>
                        <span asp-validation-for="Input.Email" class="text-danger"></span>
                    </div>

                    <!-- Password -->
                    <div class="form-floating mb-3">
                        <input asp-for="Input.Password" type="password" class="form-control" placeholder="Senha" />
                        <label asp-for="Input.Password">Palavra-passe</label>
                        <span asp-validation-for="Input.Password" class="text-danger"></span>
                    </div>

                    <!-- Remember -->
                    <div class="form-check mb-3">
                        <input class="form-check-input" asp-for="Input.RememberMe" />
                        <label class="form-check-label" asp-for="Input.RememberMe">
                            Lembrar-me
                        </label>
                    </div>

                    <!-- Button -->
                    <button type="submit" class="btn btn-primary w-100 btn-lg">
                        Entrar
                    </button>

                    <!-- Links -->
                    <div class="text-center mt-3">
                        <a asp-page="./ForgotPassword" class="d-block">Esqueceu a palavra-passe?</a>
                        <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl" class="d-block mt-1">
                            Criar nova conta
                        </a>
                        <a asp-page="./ResendEmailConfirmation" class="d-block mt-1">
                            Reenviar confirmação de email
                        </a>
                    </div>

                </form>
            </div>
        </div>

        <!-- External login -->
        <div class="card mt-3 shadow-sm border-0 rounded-4">
            <div class="card-body text-center">

                <h5 class="mb-3">Ou entra com:</h5>

                @{
                    if ((Model.ExternalLogins?.Count ?? 0) == 0)
                    {
                        <p class="text-muted small">
                            Nenhum serviço externo configurado.
                        </p>
                    }
                    else
                    {
                        <form asp-page="./ExternalLogin" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                            @foreach (var provider in Model.ExternalLogins!)
                            {
                                <button type="submit" class="btn btn-outline-dark w-100 mb-2"
                                        name="provider" value="@provider.Name">
                                    Entrar com @provider.DisplayName
                                </button>
                            }
                        </form>
                    }
                }

            </div>
        </div>

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}